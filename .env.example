COMPOSE_PROJECT_NAME=worldcup-ai-prediction

WEB_HOST_PORT=3000
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

POSTGRES_DB=worldcup_ai_prediction
POSTGRES_USER=worldcup_app
POSTGRES_PASSWORD=worldcup_app_dev_password

REDIS_PASSWORD=worldcup_redis_dev_password

DATABASE_URL=postgresql://worldcup_app:worldcup_app_dev_password@localhost:5432/worldcup_ai_prediction
REDIS_URL=redis://:worldcup_redis_dev_password@localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=worldcup_document_chunks
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine

TOKEN_LOW_BALANCE_THRESHOLD=10000
ENVIRONMENT=local
LOG_LEVEL=info
HEALTHCHECK_HOST=127.0.0.1

OPENAI_API_KEY=replace_with_local_api_key
FOOTBALL_DATA_API_KEY=replace_with_local_api_key
